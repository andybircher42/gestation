{
  "expo": {
    "name": "In Due Time",
    "slug": "in-due-time",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3f3f1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.andybircher.induetime",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.andybircher.induetime"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4d065921-dd8c-4b05-88c3-3a8b2bfa13f7"
    },
    "extra": {
      "eas": {
        "projectId": "4d065921-dd8c-4b05-88c3-3a8b2bfa13f7"
      }
    },
    "owner": "andybircher"
  }
}
